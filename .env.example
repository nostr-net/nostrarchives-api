DATABASE_URL=postgres://dev:dev@localhost:5432/nostr_api
REDIS_URL=redis://127.0.0.1:6379

# ClickHouse analytics (optional — enables columnar analytics engine).
# When set, analytics queries use ClickHouse instead of Postgres materialized views.
# CLICKHOUSE_URL=http://localhost:8123
LISTEN_ADDR=0.0.0.0:8000
RUST_LOG=nostr_api=info

# Comma-separated relay WebSocket URLs
RELAY_URLS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.primal.net,wss://nostr.wine

# Relay discovery controls
ENABLE_RELAY_DISCOVERY=true
RELAY_INDEXERS=wss://relay.damus.io,wss://relay.primal.net,wss://indexer.coracle.social,wss://relay.nos.social
RELAY_DISCOVERY_TARGET=25
ENABLE_SOCIAL_GRAPH_BOOTSTRAP=true

# Unix timestamp — only ingest events created after this time.
# Omit or leave empty to use current time (recommended for first run).
# INGESTION_SINCE=0

# Negentropy: primary relays tried for every per-author crawl (comma-separated).
# If unset, falls back to all DB-known negentropy-capable relays.
# NEGENTROPY_RELAY_URLS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.primal.net,wss://nostr.wine

# Crawl mode: "hybrid" (default, full 3-phase crawler) or "negentropy_only" (simple per-author negentropy sync)
# CRAWL_MODE=hybrid

# Pinned relays for negentropy_only mode (tested at boot for negentropy+author support).
# Defaults to well-known relays if unset.
# NEGENTROPY_PINNED_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.nostr.band,wss://nostr.wine,wss://purplepag.es,wss://relay.nos.social

# Intelligent crawler — backfills historical notes per author
ENABLE_CRAWLER=false
CRAWLER_BATCH_SIZE=10
CRAWLER_EVENTS_PER_AUTHOR=200
CRAWLER_REQUEST_DELAY_MS=500
